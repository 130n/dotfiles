{
  "ruff.enable": true,
  // NOTE: Add your Anthropic API key in User Settings (not here!)
  // File > Preferences > Settings > search for "anthropic.apiKey"
  "search.exclude": {
    "**/venv": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/logicapps": true,
    "**/build": true,
    "**/dist": true
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "always"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "python.defaultInterpreterPath": "./backend/.venv/bin/python"
}
